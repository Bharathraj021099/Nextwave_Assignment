{
  "info": {
    "name": "Task Tracker API",
    "description": "Team Task Tracker REST API — SDE II Assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:3000/api", "type": "string" },
    { "key": "accessToken",  "value": "",                          "type": "string" },
    { "key": "refreshToken", "value": "",                          "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (creates org + first ADMIN user)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.data) {",
            "  pm.collectionVariables.set('accessToken',  r.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', r.data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice Admin\",\n  \"email\": \"alice@acme.com\",\n  \"password\": \"Secret123\",\n  \"orgName\": \"Acme Corp\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.data) {",
            "  pm.collectionVariables.set('accessToken',  r.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', r.data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@acme.com\",\n  \"password\": \"Secret123\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.data) {",
            "  pm.collectionVariables.set('accessToken',  r.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', r.data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["users"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }] }
          }
        },
        {
          "name": "Invite User (ADMIN only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bob Manager\",\n  \"email\": \"bob@acme.com\",\n  \"password\": \"Secret123\",\n  \"role\": \"MANAGER\"\n}" }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/:id"
          }
        },
        {
          "name": "Update Role (ADMIN only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/:id/role",
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"MANAGER\"\n}" }
          }
        },
        {
          "name": "Remove User (ADMIN only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/:id"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "Create Project (ADMIN / MANAGER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/projects",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Website Redesign\",\n  \"description\": \"Redesign the public-facing website\"\n}" }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/:id"
          }
        },
        {
          "name": "Update Project (ADMIN / MANAGER)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/projects/:id",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Website Redesign v2\"\n}" }
          }
        },
        {
          "name": "Delete Project (ADMIN only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/:id"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks (paginated + filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page",       "value": "1" },
                { "key": "limit",      "value": "10" },
                { "key": "status",     "value": "TODO",     "disabled": true },
                { "key": "priority",   "value": "HIGH",     "disabled": true },
                { "key": "assigneeId", "value": "<uuid>",   "disabled": true },
                { "key": "projectId",  "value": "<uuid>",   "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Task (ADMIN / MANAGER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/tasks",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Implement login page\",\n  \"description\": \"Build the login form with validation\",\n  \"priority\": \"HIGH\",\n  \"assigneeId\": null,\n  \"dueDate\": \"2026-12-31T23:59:59Z\"\n}" }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/tasks/:id"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/tasks/:id",
            "body": { "mode": "raw", "raw": "{\n  \"priority\": \"MEDIUM\",\n  \"dueDate\": \"2027-01-15T00:00:00Z\"\n}" }
          }
        },
        {
          "name": "Update Task Status (assignee or MANAGER/ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/tasks/:id/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" }
          }
        },
        {
          "name": "Delete Task (ADMIN / MANAGER)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/tasks/:id"
          }
        }
      ]
    },
    {
      "name": "Misc",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/health"
          }
        }
      ]
    }
  ]
}
